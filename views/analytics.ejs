<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics | LinkSnip</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #4f46e5, #06b6d4);
            background-attachment: fixed;
            color: #111827;
            padding: 28px 18px 40px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header-card {
            background: rgba(255, 255, 255, 0.93);
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.14);
            margin-bottom: 20px;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .back-btn {
            text-decoration: none;
            color: #4f46e5;
            background: #ede9fe;
            padding: 8px 14px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
        }

        .click-badge {
            background: #dcfce7;
            color: #166534;
            padding: 8px 14px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
        }

        .title {
            font-size: 24px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 5px;
            word-break: break-all;
        }

        .subtitle {
            font-size: 14px;
            color: #4b5563;
            word-break: break-all;
        }

        .subtitle a {
            color: #4b5563;
            text-decoration: none;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 16px;
            padding: 18px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
        }

        .stat-label {
            color: #6b7280;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 26px;
            font-weight: 800;
            color: #1f2937;
        }

        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 14px;
            margin-bottom: 20px;
        }

        .chart-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
        }

        .chart-card h3 {
            font-size: 15px;
            margin-bottom: 10px;
            color: #111827;
        }

        .chart-holder {
            position: relative;
            min-height: 280px;
        }

        .table-and-qr {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 14px;
        }

        .table-card,
        .qr-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.1);
        }

        .table-card h3,
        .qr-card h3 {
            font-size: 15px;
            margin-bottom: 12px;
            color: #111827;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            text-align: left;
            padding: 10px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 13px;
            color: #374151;
        }

        th {
            color: #6b7280;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: #f9fafb;
        }

        .empty-row {
            text-align: center;
            color: #9ca3af;
            padding: 16px;
        }

        .qr-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 10px;
        }

        .qr-wrap img {
            width: 220px;
            max-width: 100%;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: white;
            padding: 10px;
        }

        @media (max-width: 980px) {
            .stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .charts-grid,
            .table-and-qr {
                grid-template-columns: 1fr;
            }

            .chart-holder {
                min-height: 240px;
            }
        }

        @media (max-width: 560px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .title {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <section class="header-card">
            <div class="header-top">
                <a class="back-btn" href="/">&larr; Back</a>
                <span class="click-badge"><%= analyticsData.totalClicks %> Total Clicks</span>
            </div>
            <div class="title"><%= (process.env.BASE_URL || 'http://localhost:8002') + '/' + url.shortId %></div>
            <div class="subtitle">Original URL: <a href="<%= url.redirectURL %>" target="_blank" rel="noreferrer"><%= url.redirectURL %></a></div>
        </section>

        <section class="stats-grid">
            <article class="stat-card">
                <div class="stat-label">Total Clicks</div>
                <div class="stat-value"><%= analyticsData.totalClicks %></div>
            </article>
            <article class="stat-card">
                <div class="stat-label">Unique Countries</div>
                <div class="stat-value"><%= analyticsData.uniqueCountries %></div>
            </article>
            <article class="stat-card">
                <div class="stat-label">Top Device</div>
                <div class="stat-value"><%= analyticsData.topDevice %></div>
            </article>
            <article class="stat-card">
                <div class="stat-label">Top Browser</div>
                <div class="stat-value"><%= analyticsData.topBrowser %></div>
            </article>
        </section>

        <section class="charts-grid">
            <article class="chart-card">
                <h3>Clicks Over Time (Last 30 Days)</h3>
                <div class="chart-holder"><canvas id="lineChart"></canvas></div>
            </article>
            <article class="chart-card">
                <h3>Device Breakdown</h3>
                <div class="chart-holder"><canvas id="deviceChart"></canvas></div>
            </article>
            <article class="chart-card">
                <h3>Country Breakdown (Top 10)</h3>
                <div class="chart-holder"><canvas id="countryChart"></canvas></div>
            </article>
            <article class="chart-card">
                <h3>Browser Breakdown</h3>
                <div class="chart-holder"><canvas id="browserChart"></canvas></div>
            </article>
        </section>

        <section class="table-and-qr">
            <article class="table-card">
                <h3>Recent Visits</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Country</th>
                            <th>Device</th>
                            <th>Browser</th>
                            <th>Referrer</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (!analyticsData.recentVisits.length) { %>
                            <tr>
                                <td colspan="5" class="empty-row">No visits yet.</td>
                            </tr>
                        <% } else { %>
                            <% analyticsData.recentVisits.forEach((visit) => { %>
                                <tr>
                                    <td><%= new Date(visit.timestamp).toLocaleString() %></td>
                                    <td><%= visit.country || 'Unknown' %></td>
                                    <td><%= visit.device || 'desktop' %></td>
                                    <td><%= visit.browser || 'Unknown' %></td>
                                    <td><%= visit.referrer || 'Direct' %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </article>

            <article class="qr-card">
                <h3>QR Code</h3>
                <div class="qr-wrap">
                    <img src="/url/qr/<%= url.shortId %>" alt="QR code for <%= url.shortId %>">
                </div>
            </article>
        </section>
    </div>

    <script id="analyticsPayload" type="application/json"><%- JSON.stringify(analyticsData) %></script>
    <script>
        const data = JSON.parse(document.getElementById('analyticsPayload').textContent);

        const lineLabels = Object.keys(data.clicksByDate);
        const lineValues = Object.values(data.clicksByDate);

        new Chart(document.getElementById('lineChart'), {
            type: 'line',
            data: {
                labels: lineLabels,
                datasets: [{
                    label: 'Clicks',
                    data: lineValues,
                    borderColor: '#4f46e5',
                    backgroundColor: 'rgba(79, 70, 229, 0.2)',
                    tension: 0.3,
                    fill: true,
                }],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
            },
        });

        new Chart(document.getElementById('deviceChart'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(data.deviceBreakdown),
                datasets: [{
                    data: Object.values(data.deviceBreakdown),
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b'],
                }],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
            },
        });

        const countryLabels = Object.keys(data.countryBreakdown);
        const countryValues = Object.values(data.countryBreakdown);

        new Chart(document.getElementById('countryChart'), {
            type: 'bar',
            data: {
                labels: countryLabels,
                datasets: [{
                    label: 'Clicks',
                    data: countryValues,
                    backgroundColor: '#06b6d4',
                    borderRadius: 6,
                }],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                },
            },
        });

        new Chart(document.getElementById('browserChart'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(data.browserBreakdown),
                datasets: [{
                    data: Object.values(data.browserBreakdown),
                    backgroundColor: ['#8b5cf6', '#ef4444', '#f97316', '#22c55e', '#14b8a6', '#f43f5e', '#6366f1'],
                }],
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
            },
        });
    </script>
</body>
</html>
